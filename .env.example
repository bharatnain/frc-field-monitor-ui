# Direct mode: browser talks straight to the field server.
VITE_FIELD_MONITOR_BASE_URL=http://10.0.100.5

# Proxy mode: uncomment this and rebuild to point the browser at the internal proxy server instead.
# VITE_FIELD_MONITOR_BASE_URL=http://localhost:3000

# Internal proxy upstream target for REST + SignalR traffic.
FIELD_MONITOR_UPSTREAM_URL=http://10.0.100.5

# Internal proxy listen port.
PORT=3000
