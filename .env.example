# Choose one browser connection mode:
#
# 1. Direct mode
#    Use this when the browser can reach the field server directly.
#    Uncomment the next line, then run `npm run dev`.
# VITE_FIELD_MONITOR_BASE_URL=http://10.0.100.5
#
# 2. Proxy mode
#    Use this when you serve the app with `npm start` on port 3000.
#    Leave `VITE_FIELD_MONITOR_BASE_URL` unset so the browser uses same-origin
#    requests to the local proxy instead of hardcoding a remote browser base URL.

# Internal proxy upstream target for REST + SignalR traffic.
FIELD_MONITOR_UPSTREAM_URL=http://10.0.100.5

# Internal proxy listen port.
PORT=3000
